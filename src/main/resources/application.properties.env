spring.application.name=ai
server.port=8888

spring.datasource.url=${DB_URL:jdbc:mysql://xxxx:3306/ai?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true}
spring.datasource.username=${DB_USERNAME:root}
spring.datasource.password=${DB_PASSWORD:xxxxx}
spring.datasource.driver-class-name=${DB_DRIVER:com.mysql.cj.jdbc.Driver}

mybatis-plus.configuration.map-underscore-to-camel-case=true
#spring.sql.init.mode=always
#spring.sql.init.continue-on-error=true

spring.ai.openai.base-url=${AI_BASE_URL:https://ai.input.im}
spring.ai.openai.api-key=${AI_API_KEY:replace-with-api-key}
spring.ai.openai.chat.options.model=${OPENAI_CHAT_MODEL:gpt-5.4}

spring.ai.openai.grok.base-url=${GROK_BASE_URL:https://newapi.makelove.cloud}
spring.ai.openai.grok.api-key=${GROK_API_KEY:replace-with-api-key}
spring.ai.openai.grok.chat.options.model=${GROK_CHAT_MODEL:grok-4.3}

# JWT
jwt.secret=${JWT_SECRET:please-change-this-to-a-long-random-secret-at-least-32-bytes}
jwt.expire-minutes=${JWT_EXPIRE_MINUTES:120}
jwt.header=Authorization
jwt.prefix=Bearer
